{
  "name": "cerco-resume-site",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm:watch:css\" \"npm:serve\"",
    "build:css": "tailwindcss -i ./src/tailwind.css -o ./style.css --minify",
    "watch:css": "tailwindcss -i ./src/tailwind.css -o ./style.css --watch",
    "serve": "serve . -l 4173"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.0",
    "concurrently": "^9.1.2",
    "serve": "^14.2.4",
    "tailwindcss": "^4.1.0"
  }
}